{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "types": ["chrome"],
    "resolveJsonModule": true,
    "jsx": "react"
  },
  "include": ["src", "vite.config.ts"]
}
