{
  "manifest_version": 3,
  "name": "Time Out: Page Blocker",
  "version": "3.0.0",
  "description": "Stay Focused & Mindful of Your Browsing.",
  "permissions": [
    "storage",
    "tabs",
    "notifications",
    "alarms",
    "contextMenus"
  ],
  "action": {
    "default_popup": "src/entries/popup/index.html",
    "default_title": "Time Out: Page Blocker",
    "default_icon": {
      "16": "src/assets/icons/icon16.png",
      "32": "src/assets/icons/icon32.png",
      "48": "src/assets/icons/icon48.png",
      "128": "src/assets/icons/icon128.png"
    }
  },
  "options_page": "src/entries/options/index.html",
  "background": {
    "service_worker": "src/entries/background/index.ts",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/entries/block-page/index.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    },
    {
      "resources": [
        "public/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
